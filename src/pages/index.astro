---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { getCollection } from "astro:content";

// const posts = (await getCollection("blog")).sort(
//   (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
// );

// const last_posts = posts.slice(0, 3);
---

<BaseLayout>
  <div class="pb-12 mt-5">
    <!-- <div class="text-xl py-1">Hey there 👋</div> -->
    <div class="text-5xl font-bold">Hidekazu Nagamura (長村 秀一)</div>
    <div class="text-3xl py-3 font-bold">
      Project Researcher at <a href="https://www.doshisha.ac.jp">Cybernetic Humanity</a>, <a href="https://www.sonycsl.co.jp">Sony CSL</a>
    </div>
    <div class="py-2">
      <p class="text-lg">
        <a href="https://www.sonycsl.co.jp">ソニーCSL</a> プロジェクト研究員の長村です。
        私は自己や主観経験、メタ認知のメカニズムに興味があり、現在は自己認知を心理実験などを用いて調べています。他に、各人固有の認知的環世界の調査・実装に興味があります。趣味は音楽、読書、サウナ、お茶です。
      </p>
      <p class="text-lg mt-2 text-base-content/70">
        I am Hidekazu Nagamura, a Project Researcher at <a href="https://www.sonycsl.co.jp">Sony CSL</a>.
        I am interested in the mechanisms of self, subjective experience, and metacognition. Currently, I investigate sense of self through psychological experiments. I am also interested in studying and modeling each person's unique cognitive Umwelt. My hobbies include music, reading, sauna, and tea.
      </p>
    </div>
  </div>

  <div class="mb-5">
    <div class="text-2xl w-full font-bold mb-3">News</div>
    <ul class="grid gap-3">
      <li class="flex items-start gap-3">
        <span class="badge badge-outline text-xs whitespace-nowrap mt-0.5">2026/4/1</span>
        <span>
          ソニーCSLのCybernetic Humanityプロジェクトに、プロジェクト研究員として着任しました。<br />
          <span class="text-base-content/70">Joined the Cybernetic Humanity Project at Sony CSL as a Project Researcher.</span>
        </span>
      </li>
    </ul>
  </div>


  <div>
    <div class="text-3xl w-full font-bold mb-2">Latest Publications</div>
  </div>

  <div class="mb-5">
    <div class="text-2xl w-full font-bold">Articles</div>
  </div>

  <ul class="list-decimal mx-6 mb-10 grid gap-2">
    <li>
      <span class="underline">Hidekazu Nagamura</span>, Hiroshi Onishi, 
      Kohta I. Kobayasi, Shoko Yuki, "Implicit manifestation of prospective 
      metacognition in betting choices enhances its efficiency compared to 
      explicit expression", Frontiers in Human Neuroscience, vol. 19, 2025 (
      <a
        href="https://doi.org/10.3389/fnhum.2025.1490530"
        target="_blank"
        class="hover:underline">https://doi.org/10.3389/fnhum.2025.1490530</a>)
    </li>
    <li>
      Miku Uenaka, <span class="underline">Hidekazu Nagamura</span>, Shizuko
      Hiryu, Kohta I. Kobayasi, Yuta Tamai, “Feasibility evaluation of
      transtympanic laser stimulation of the cochlea from the outer ear”,
      Journal of the Acoustical Society of America, vol. 152, pp. 1850-1855,
      2022 (<a
        href="https://doi.org/10.1121/10.0014241"
        target="_blank"
        class="hover:underline">https://doi.org/10.1121/10.0014241</a
      >)
    </li>
  </ul>

  <div class="mb-5">
    <div class="text-2xl w-full font-bold">Preprints / プレプリント</div>
  </div>

  <ul class="list-decimal mx-6 mb-10 grid gap-2">
    <li>
      <span class="underline">Hidekazu Nagamura</span>, Hiroshi Onishi, Momoko
      Hishitani, Shota Murai, Yuma Osako, Kohta I. Kobayasi, “Reward priming
      differentially modulates enhancement and inhibition in auditory
      decision-making”, bioRxiv. (<a
        href="https://doi.org/10.1101/2021.12.23.473984"
        target="_blank"
        class="hover:underline">https://doi.org/10.1101/2021.12.23.473984</a
      >)
    </li>
  </ul>

  <!-- <div>
    <div class="text-3xl w-full font-bold mb-5 mt-10">Latest from blog</div>
  </div>

  {
    last_posts.map((post) => (
      <>
        <HorizontalCard
          title={post.data.title}
          img={post.data.heroImage}
          desc={post.data.description}
          url={"/blog/" + post.slug}
          target="_self"
        />
        <div class="divider my-0" />
      </>
    ))
  } -->
</BaseLayout>
